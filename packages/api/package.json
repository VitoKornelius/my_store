{
  "name": "@acme/api",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "exports": {
    "./_generated": {
      "types": "./.mercur/_generated/index.ts"
    }
  },
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:marketplace": "medusa exec ./src/scripts/seed-marketplace-demo.ts",
    "seed:catalog": "medusa exec ./src/scripts/seed-large-catalog.ts",
    "seed:more-products": "medusa exec ./src/scripts/seed-more-products.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@inquirer/checkbox": "2.3.11",
    "@inquirer/input": "2.2.9",
    "@medusajs/admin-sdk": "^2.13.4",
    "@medusajs/admin-shared": "^2.13.4",
    "@medusajs/cli": "^2.13.4",
    "@medusajs/dashboard": "^2.13.4",
    "@medusajs/deps": "2.13.6",
    "@medusajs/draft-order": "2.13.4",
    "@medusajs/framework": "^2.13.4",
    "@medusajs/medusa": "^2.13.4",
    "@mercurjs/cli": "2.0.2",
    "@mercurjs/core-plugin": "2.0.2",
    "@mercurjs/types": "2.0.2",
    "@types/express": "4.17.21",
    "@types/http-proxy": "1.17.15",
    "bl": "4.1.0",
    "csv-parse": "5.6.0",
    "fs-exists-cached": "1.0.0",
    "hosted-git-info": "4.0.2",
    "http-proxy": "1.18.1",
    "http-proxy-middleware": "^3.0.3",
    "inquirer": "8.0.0",
    "ioredis": "5.4.1",
    "is-plain-object": "5.0.0",
    "is-valid-path": "0.1.1",
    "json-2-csv": "5.5.9",
    "jsonfile": "6.2.0",
    "meant": "1.0.3",
    "multer": "2.0.2",
    "node-cache": "5.1.2",
    "node-schedule": "2.1.1",
    "pg-god": "1.0.12",
    "request-ip": "3.3.0",
    "scrypt-kdf": "2.0.1",
    "slugify": "1.6.6",
    "stack-trace": "0.0.10",
    "wcwidth": "1.0.1",
    "winston": "3.9.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "^2.13.4",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
